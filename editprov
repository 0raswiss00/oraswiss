<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="UTF-8">
    <title>Modifiko Orën</title>
    <style>
        body { font-family: Arial; background: #000; color: #fff; padding: 20px; }
        form { max-width: 600px; margin: 0 auto; background: #111; padding: 20px; border-radius: 10px; }
        input, select, textarea { width: 100%; padding: 10px; margin-bottom: 10px; background: #222; color: #fff; border: 1px solid #444; border-radius: 5px; }
        button { width: 100%; padding: 15px; background: gold; border: none; font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>
<a href="dashboard.html"
    style="color:#ccc; text-align:center; display:block; margin-top:10px;">
    ← Back 
</a>
<form id="editForm">
    <h2>Modifiko Orën</h2>
    <input type="text" id="brand" placeholder="Brand" required>
    <input type="text" id="model" placeholder="Model" required>
    <input type="number" id="price" placeholder="Price">
    <textarea id="description" placeholder="Description"></textarea>
    <label for="image_input">Shto ose ndrysho fotot:</label>
    <input type="file" id="image_input" multiple accept="image/*">
    <button type="submit">Ruaj Ndryshimet</button>
    <button type="button" id="deleteBtn" style="background: #ff4d4d; color: white; width: 100%; padding: 15px; border: none; cursor: pointer; margin-top: 10px;">
        Fshi Produktin
    </button>
</form>

<div id="gallery-container" style="margin: 15px 0; display: flex; gap: 10px; flex-wrap: wrap;">
    </div>
   
<script type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

    const supabase = createClient(
        "https://gnwsrmelmeqduhhmfmoa.supabase.co", 
        "sb_publishable__AkK_Z7lhtkvukN6Fy1cAQ_KBTXIcY9"
    );

    const id = new URLSearchParams(window.location.search).get('id');

async function fetchWatch() {
    const { data, error } = await supabase
        .from('oras')
        .select('*')
        .eq('id', id)
        .single();

    if (error || !data) {
        console.log(error);
        return;
    }

    // form fields
    document.getElementById('brand').value = data.brand || "";
    document.getElementById('model').value = data.model || "";
    document.getElementById('price').value = data.price || "";
    document.getElementById('description').value = data.description || "";

    window.produktData = data;

    // =========================
    // GALERIA E SAKTË
    // =========================
    const gallery = document.getElementById('gallery-container');
    gallery.innerHTML = "";

    let images = [];

    if (Array.isArray(data.image_url)) {
        images = data.image_url;
    } else if (typeof data.image_url === "string") {
        try {
            images = JSON.parse(data.image_url);
        } catch {
            images = data.image_url.split(",").filter(Boolean);
        }
    }

    if (!images.length) {
        gallery.innerHTML = "<p>No images</p>";
        return;
    }

    images.forEach((url, index) => {
        const img = document.createElement("img");

        img.src = url.startsWith("http")
            ? url
            : "https://gnwsrmelmeqduhhmfmoa.supabase.co/storage/v1/object/public/or-images/" + url;

        img.style.width = "100px";
        img.style.cursor = "pointer";
        img.style.marginRight = "10px";

        img.onclick = () => {
            const moved = images.splice(index, 1)[0];
            images.unshift(moved);
            window.produktData.image_url = images;
            alert("Foto u bë kryesore");
        };

        gallery.appendChild(img);
    });
}

// 2. Ruaj ndryshimet
document.getElementById('editForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // SHTESË: Merr informacionin e përdoruesit të loguar
    const { data: { user }, error: userError } = await supabase.auth.getUser();
    
    if (userError || !user) {
        alert("Duhet të jesh i loguar për të bërë ndryshime!");
        return;
    }

    let imageUrls = window.produktData?.image_url || [];
    const fileInput = document.getElementById('image_input');

    if (fileInput.files.length > 0) {
        for (let i = 0; i < fileInput.files.length; i++) {
            const file = fileInput.files[i];
            const fileName = `${Date.now()}_${file.name}`;
            await supabase.storage.from('or-images').upload(fileName, file);
            const { data } = supabase.storage.from('or-images').getPublicUrl(fileName);
            imageUrls.push(data.publicUrl);
        }
    }

    // MODIFIKIMI KRYESOR:
    // Përdorim .eq('user_id', user.id) për të siguruar që RLS na lejon update-in
    const { error } = await supabase.from('oras').update({
        brand: document.getElementById('brand').value,
        model: document.getElementById('model').value,
        price: parseInt(document.getElementById('price').value),
        description: document.getElementById('description').value,
        image_url: imageUrls
    })
    .eq('id', id)
    .eq('user_id', user.id); // KY ËSHTË KRYESORI: Siguron pronësinë

    if (error) {
        console.error("Gabim:", error);
        alert("Gabim gjatë ruajtjes: " + error.message);
    } else {
        alert("Ora u modifikua me sukses!");
        window.location.href = 'dashboard.html';
    }
});
document.getElementById('deleteBtn').addEventListener('click', async () => {
    if (!confirm("A jeni i sigurt që doni ta fshini këtë orë?")) return;

    const { data: { user } } = await supabase.auth.getUser();

    const { error } = await supabase
        .from('oras')
        .delete()
        .eq('id', id)
        .eq('user_id', user.id); 

    if (error) {
        alert("Gabim gjatë fshirjes: " + error.message);
    } else {
        alert("Ora u fshi me sukses!");
        window.location.href = 'dashboard.html';
    }
});
fetchWatch();
</script>
</body>
</html>




<!DOCTYPE html>
<html lang="sq">
