// Tani përdorni variablin 'supabase' kudo në kod

async function loadCategory(cat, containerId) {
    const container = document.getElementById(containerId);
    
    const { data, error } = await supabase
        .from('oras')
        .select('*')
        .eq('category', cat); 

    if (error) {
        console.error("Gabim gjatë marrjes së të dhënave:", error);
        container.innerHTML = "Error loading items.";
        return;
    }

    if (!data || data.length === 0) {
        container.innerHTML = "No items in this category.";
        return;
    }

    // Ndërtimi i kartave dinamike
    container.innerHTML = data.map(ora => {
        
// Imazhi standard nëse nuk ka foto
        let imgUrl = "https://placeholder.co/600x400/222/fff?text=No+Image";
        let primaryImage = "";

        // Kontrolli i kolonës së re image_url (me vizë poshtë)
        if (ora.image_url && ora.image_url.length > 0) {
            primaryImage = Array.isArray(ora.image_url) ? ora.image_url[0] : ora.image_url;
        }

  if (primaryImage && primaryImage !== 'null' && primaryImage !== '') {
              if (primaryImage.startsWith('http')) {
                  imgUrl = primaryImage;
              } else {
                  imgUrl = "https://gnwsrmelmeqduhhmfmoa.supabase.co/storage/v1/object/public/or-images/" + primaryImage;
              }
          }
      
        return `
            <div class="card" onclick="window.location.href='product.html?id=${ora.id}'">
                <img src="${imgUrl}" alt="${ora.brand || 'Ora'}">
                <h3>${ora.brand || ''} - ${ora.model || ''}</h3>
                <p style="color:#aaa; font-size:14px; margin:5px 0;">Ref: ${ora.reference || '/'}</p>
                <div class="price">${ora.price ? ora.price + ' €' : 'Contact for price'}</div>
                
                <input type="email" placeholder="Emaili yt" style="width:100%; margin: 5px 0; padding:10px; background:#222; color:#fff; border:1px solid #444; border-radius:4px; box-sizing:border-box;" onclick="event.stopPropagation();">
                
                <button class="btn-main btn-secondary" style="width:100%; margin-top:5px;" onclick="event.stopPropagation();">Send Request</button>
                
                ${ora.paypal_link ? `
                <a href="${ora.paypal_link}" target="_blank" style="text-decoration:none;" onclick="event.stopPropagation();">
                    <button class="btn-main btn-buy" style="width:100%; margin-top:5px;">🛒 Buy Now</button>
                </a>
                ` : ''}

                <div style="display: flex; gap: 5px; margin-top: 5px;">
                    <button style="flex: 1; padding: 8px; background: #222; color: #fff; border: 1px solid #444; border-radius: 4px; cursor: pointer; font-size: 14px;" 
                        onclick="event.stopPropagation(); this.style.background = this.style.background === 'rgb(220, 53, 69)' ? '#222' : '#dc3545';">
                        ❤️ Like
                    </button>
                    <button style="flex: 1; padding: 8px; background: #222; color: #fff; border: 1px solid #444; border-radius: 4px; cursor: pointer; font-size: 14px;" 
                        onclick="event.stopPropagation(); navigator.clipboard.writeText(window.location.origin + '/product.html?id=${ora.id}'); alert('Link copied to clipboard!');">
                        🔗 Share
                    </button>
                </div>
            </div>
        `;
    }).join('');
}
// E vendosim tek 'window' që të jetë i aksesueshëm nga butoni në HTML
window.trajtoKlikiminSell = async function() {
  // Përdor getUser në vend të getSession
  const { data: { user } } = await supabase.auth.getUser();

  if (user) {
    // Nëse ka user, shko te faqja e shitjes
    window.location.href = 'register.html'; 
  } else {
    // Nëse nuk ka user, dërgoje te logimi
    window.location.href = 'login.html'; 
  }
};

// Funksioni për ta shfaqur butonin vetëm kur përdoruesi është i loguar
async function kontrolloDheShfaqSellNow() {
    const { data: { session } } = await supabase.auth.getSession();
    const btnSell = document.getElementById("btnSellNow");
    if (session && btnSell) {
        btnSell.style.display = "block"; 
    }
}

// E thërrasim funksionin sapo faqja të hapet
kontrolloDheShfaqSellNow();
  
    // Ngarkimi i kategorive
