// Funksioni për të numëruar produktet (orët)
async function loadProductCount() {
    try {
        console.log("Duke u lidhur me Supabase për produkte...");
        const { count, error } = await supabase
            .from('oras') // Përdor tabelën 'oras' që konfirmuat
            .select('*', { count: 'exact' });

        if (error) {
            console.error("GABIM SUPABASE:", error);
        } else {
            console.log("Numri i produkteve:", count);
            const element = document.getElementById('count-products');
            if (element) {
                element.textContent = count || 0;
            }
        }
    } catch (err) {
        console.error("Gabim i papritur:", err);
    }
}

// Funksioni për të numëruar përdoruesit
async function loadUserCount() {
    try {
        const { data, error } = await supabase
            .from('oras')
            .select('user_id');
        
        if (error) throw error;
        
        const uniqueUsers = [...new Set(data?.map(w => w.user_id).filter(Boolean))];
        document.getElementById('count-users').textContent = uniqueUsers.length;
    } catch (err) {
        console.error("Gabim te loadUserCount:", err);
    }
}

// Thirr funksionet këtu (jashtë çdo funksioni tjetër)
loadUserCount();
loadProductCount();

