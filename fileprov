    const btnSell = document.getElementById("btnSellNow");
    if (session && btnSell) {
        btnSell.style.display = "block"; 
    }
}

// E thërrasim funksionin sapo faqja të hapet
kontrolloDheShfaqSellNow();
  
    // Ngarkimi i kategorive
