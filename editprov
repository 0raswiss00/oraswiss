</a>
<form id="editForm">
    <h2>Modifiko Orën</h2>
    <input type="text" id="brand" placeholder="Brand" required>
    <input type="text" id="model" placeholder="Model" required>
    <input type="number" id="price" placeholder="Price">
    <textarea id="description" placeholder="Description"></textarea>
    <label for="image_input">Shto ose ndrysho fotot:</label>
    <input type="file" id="image_input" multiple accept="image/*">
    <button type="submit">Ruaj Ndryshimet</button>
    <button type="button" id="deleteBtn" style="background: #ff4d4d; color: white; width: 100%; padding: 15px; border: none; cursor: pointer; margin-top: 10px;">
